# To validate, run:
#   'git ls-files -i --exclude-standard'

# build generated files
/include/hbverbld.h
bin/*/
lib/*/
obj
.hbmk/
*.hbl
*.hbd
*.hbr
*.hrb

# 'install'-ed binaries
*.exe
*.dll
*.dxe
*.dylib
*.so
*.sl
*.lib
*.a

# packages
/pkg/

# not hosted contribs
/addons/

# misc junk
.DS_Store
*.bak

# exceptions
!libunicows.a
!unicows.lib
!lib/3rd
!config/*.exe
!/*.exe

# LLVM backend local build/report output
/build/

# Bundled MinGW runtime (CRT objects + import libs) shipped with the
# LLVM backend so harbour -GL links without an external toolchain.
!lib/win/mingw64-rt/
!lib/win/mingw64-rt/**
